# ======================================================================
# Omega Prime X — Environment Configuration
# Copy to `.env` and adjust. The platform boots with ZERO external
# dependencies using the in-memory seeded datastore (DATA_BACKEND=memory).
# Switch to Postgres for persistence once Docker Compose is up.
# ======================================================================

# --- Core ---
NODE_ENV=development
LOG_LEVEL=info

# --- Backend API ---
BACKEND_PORT=8080
BACKEND_HOST=0.0.0.0
# CORS origin allowed to call the API (the cockpit)
CORS_ORIGIN=http://localhost:3000

# --- Data backend: "memory" (default, seeded, no DB needed) | "postgres" ---
DATA_BACKEND=memory

# --- Postgres (only used when DATA_BACKEND=postgres) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=omega
POSTGRES_USER=omega
POSTGRES_PASSWORD=omega
DATABASE_URL=postgresql://omega:omega@localhost:5432/omega

# --- Redis (reserved for future queue/cache; not required for v1 boot) ---
REDIS_URL=redis://localhost:6379

# --- Frontend cockpit ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# --- Connector API keys (optional; mock connectors used when absent) ---
# MARKET_DATA_API_KEY=
# NEWS_API_KEY=
# TRANSCRIPTS_API_KEY=

# --- LLM agent reasoning (optional; deterministic heuristic agents used when absent) ---
# ANTHROPIC_API_KEY=
OMEGA_AGENT_MODE=heuristic
